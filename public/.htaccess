# ---------------------------------------------------------------
# Security headers (Apache mod_headers)
# ---------------------------------------------------------------
<IfModule mod_headers.c>
    # Prevent clickjacking
    Header always set X-Frame-Options "SAMEORIGIN"
    # Prevent MIME-type sniffing
    Header always set X-Content-Type-Options "nosniff"
    # Enable XSS filter in older browsers
    Header always set X-XSS-Protection "1; mode=block"
    # Referrer policy
    Header always set Referrer-Policy "strict-origin-when-cross-origin"
    # Basic Content-Security-Policy — tighten per your frontend needs
    Header always set Content-Security-Policy "default-src 'self'; script-src 'self' 'unsafe-inline' 'unsafe-eval'; worker-src blob:; style-src 'self' 'unsafe-inline' https://fonts.bunny.net; img-src 'self' data: blob: https://ui-avatars.com; font-src 'self' data: https://fonts.bunny.net; connect-src 'self';"
    # Remove server fingerprint header
    Header always unset X-Powered-By
    Header always unset Server
</IfModule>

# ---------------------------------------------------------------
# Block direct access to sensitive files
# ---------------------------------------------------------------
<FilesMatch "(^\.env|composer\.(json|lock)|package(-lock)?\.json|phpunit\.xml|artisan)$">
    Require all denied
</FilesMatch>

# ---------------------------------------------------------------
# Laravel routing + security rewrites
# ---------------------------------------------------------------
<IfModule mod_rewrite.c>
    <IfModule mod_negotiation.c>
        Options -MultiViews -Indexes
    </IfModule>

    RewriteEngine On

    # Block xmlrpc, wp-login and other WordPress scanners
    RewriteRule ^(xmlrpc\.php|wp-login\.php|wp-admin|\.git|\.svn) - [F,L]

    # Block PHP files anywhere under public/ EXCEPT index.php
    RewriteCond %{REQUEST_URI} \.php$ [NC]
    RewriteCond %{REQUEST_URI} !^/index\.php$ [NC]
    RewriteRule ^ - [F,L]

    # Block shell/eval patterns in query strings
    RewriteCond %{QUERY_STRING} (base64_encode|eval\(|<script|GLOBALS|_REQUEST) [NC]
    RewriteRule .* - [F,L]

    # Block null bytes
    RewriteCond %{QUERY_STRING} \0
    RewriteRule .* - [F,L]

    # Handle Authorization Header
    RewriteCond %{HTTP:Authorization} .
    RewriteRule .* - [E=HTTP_AUTHORIZATION:%{HTTP:Authorization}]

    # Handle X-XSRF-Token Header
    RewriteCond %{HTTP:x-xsrf-token} .
    RewriteRule .* - [E=HTTP_X_XSRF_TOKEN:%{HTTP:X-XSRF-Token}]

    # Redirect Trailing Slashes If Not A Folder...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_URI} (.+)/$
    RewriteRule ^ %1 [L,R=301]

    # Send Requests To Front Controller...
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteRule ^ index.php [L]
</IfModule>
